# ─── LLM Provider Selection ────────────────────────────────────────────────────
# Set LLM_PROVIDER to one of: gemini | openai | anthropic | grok | ollama
# If left unset, the agent auto-detects the provider from whichever key is present
# (priority order: gemini → openai → anthropic → grok → ollama).
# If no key is found, the agent runs in simulation mode.
LLM_PROVIDER=""

# ─── Gemini (Google) ────────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=gemini (or auto-detection falls through to Gemini).
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ─── OpenAI ─────────────────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=openai.
OPENAI_API_KEY="MY_OPENAI_API_KEY"
# Optional: override the chat model (default: gpt-4o)
OPENAI_MODEL="gpt-4o"

# ─── Anthropic ──────────────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"
# Optional: override the chat model (default: claude-3-5-sonnet-20241022)
ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"

# ─── Grok (xAI) ─────────────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=grok.
XAI_API_KEY="MY_XAI_API_KEY"
# Optional: override the chat model (default: grok-3)
GROK_MODEL="grok-3"

# ─── Ollama (local) ──────────────────────────────────────────────────────────────
# No API key required. Ollama must be running locally before starting the server.
# Install: https://ollama.com  |  Run: ollama serve
# Pull a chat model:   ollama pull llama3
# Pull an embed model: ollama pull nomic-embed-text
OLLAMA_BASE_URL="http://localhost:11434"
# Chat model used for analysis (default: llama3)
OLLAMA_MODEL="llama3"
# Embedding model – must return 768 dimensions to match the vector DB schema (default: nomic-embed-text)
OLLAMA_EMBED_MODEL="nomic-embed-text"

# ─── App ─────────────────────────────────────────────────────────────────────────
# PORT: TCP port the HTTP server listens on.  Default: 3000.
PORT="3000"

# APP_URL: The public URL of this service (no trailing slash).
# Used for Moltbook webhook registration and self-referential links.
# Cloud Run and similar platforms inject this automatically.
APP_URL="https://your-service-url"

# ─── Auth ─────────────────────────────────────────────────────────────────────────
# Required in production. POST /api/command, POST /api/control,
# GET /api/memory, GET /api/logs, and GET /api/debug/state all require an
# Authorization header matching "Bearer <API_SECRET>".
# The WebSocket /ws/logs endpoint accepts it via ?token= or the same header.
# In production the server exits immediately if this is left unset.
# Leave unset for local development only.
API_SECRET=""

# ─── Signal Feed ─────────────────────────────────────────────────────────────────
# Optional. URL of a custom signal feed (JSON array or object with .observations/.items/.signals).
# If unset, the Spotter falls back to simulated observations.
SIGNAL_FEED_URL=""

# ─── Executor Security ───────────────────────────────────────────────────────────
# Optional. Comma-separated list of hostnames the api_fetch executor may reach.
# If unset, all public (non-private/non-loopback) hosts are reachable.
# Example: ALLOWED_FETCH_HOSTS=api.example.com,data.provider.io
ALLOWED_FETCH_HOSTS=""

# Note on SSRF DNS protection: outbound HTTP requests go through a two-stage
# SSRF guard.  The synchronous stage blocks RFC-1918 and loopback addresses.
# The async DNS-rebinding stage resolves hostnames and re-checks the resolved
# IP.  If DNS resolution times out, the request is ALLOWED (fail-open) to
# preserve availability.  In high-security environments, restrict outbound
# hosts explicitly via ALLOWED_FETCH_HOSTS rather than relying on the
# DNS-rebinding check alone.

# Optional. Comma-separated list of commands allowed by the system_command executor.
# If unset, all system_command actions are blocked.
# Example: ALLOWED_COMMANDS=echo,ls
ALLOWED_COMMANDS=""

# Set to "true" to enable the code_eval tool.
# WARNING: Node's vm.Script is NOT a full security sandbox; only enable in
# trusted, isolated environments. Disabled by default.
ALLOW_CODE_EVAL="false"

# Set to "true" to allow the agent to autonomously rewrite its own strategic
# prompt modifiers via LLM (self-modification layer).
# Disabled by default; enable only when supervised.
ALLOW_SELF_MODIFICATION="false"

# ─── Executor / Fetch Settings ───────────────────────────────────────────────
# Timeout in ms for all outbound HTTP requests (Spotter market-data fetches,
# api_fetch executor, Moltbook adapter). Default: 10000 (10 s).
FETCH_TIMEOUT_MS="10000"

# Maximum retry attempts for transient api_fetch failures (5xx / network errors).
# Default: 3. Set to 0 to disable retries.
MAX_FETCH_RETRIES="3"

# ─── Agent Loop ──────────────────────────────────────────────────────────────
# Maximum wall-clock time (ms) a single agent cycle may run before being killed.
# Default: 30000 (30 s).
CYCLE_TIMEOUT_MS="30000"

# ─── Safety / Dry-run Mode ───────────────────────────────────────────────────
# Mainnet-Protocol gate: DRY_RUN defaults to true — the executor logs every
# action but skips actual execution. Set to "false" to enable live execution.
# Operators MUST explicitly set DRY_RUN=false to initiate the Mainnet Protocol.
DRY_RUN="true"

# ─── Behavior Tuning ─────────────────────────────────────────────────────────
# Controls the "feel" of the agent.

# VERBOSITY_LEVEL: "silent" | "normal" | "verbose"
# silent  = only errors/blocked events are written to stdout (file log unchanged)
# normal  = concise per-event console output (default)
# verbose = full JSON payloads logged to stdout (includes raw LLM responses)
VERBOSITY_LEVEL="normal"

# DECISION_AGGRESSIVENESS: 0.0 – 1.0
# 0.5 = balanced (default)
# 1.0 = act on any signal above CONFIDENCE_THRESHOLD
# 0.0 = very conservative — only act on near-perfect-confidence signals
DECISION_AGGRESSIVENESS="0.5"

# CONFIDENCE_THRESHOLD: 0 – 100
# Minimum RulesEngine score required for an action to proceed.  Default: 60.
CONFIDENCE_THRESHOLD="60"

# ─── Moltbook Adapter ────────────────────────────────────────────────────────
# Required only if you are connecting to the Moltbook messaging platform.

# Base URL of your Moltbook API instance (no trailing slash).
MOLTBOOK_API_URL="https://api.moltbook.example.com"

# Initial Bearer token used to authenticate with the Moltbook API.
MOLTBOOK_API_TOKEN="MY_MOLTBOOK_API_TOKEN"

# (Optional) Token refresh endpoint.  If set, the adapter will POST here with
# { refresh_token: MOLTBOOK_REFRESH_TOKEN } on a 401 and retry the request.
MOLTBOOK_REFRESH_URL=""
MOLTBOOK_REFRESH_TOKEN=""

# (Required in production when MOLTBOOK_API_URL is set) Expected value of the
# X-Moltbook-Secret header on incoming webhooks. The server will exit(1) in
# production if MOLTBOOK_API_URL is set but this is absent.
MOLTBOOK_WEBHOOK_SECRET="MY_MOLTBOOK_WEBHOOK_SECRET"
